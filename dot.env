#################################
# grpc server settings
#################################

GRPC_ADDR=0.0.0.0:9100
USE_GRPC_WEB=true

SQLITE_URL=sqlite://./conductor.sqlite3
SQLITE_MAX_CONNECTIONS=20

REDIS_URL=redis://127.0.0.1:6379

MEMORY_CACHE_NUM_COUNTERS=12960
MEMORY_CACHE_MAX_COST=1000000
MEMORY_CACHE_USE_METRICS=true

#################################
# register-workers subcommand
#################################
#JOBWORKERP_URL=http://localhost:9000
#CONDUCTOR_GRPC_URL=http://localhost:9090

#################################
# slack options
#################################
SLACK_BOT_TOKEN=<your token>

# LOGS
#LOG_LEVEL=DEBUG
LOG_LEVEL=INFO
LOG_FILE_DIR=log/
LOG_USE_JSON=false
LOG_USE_STDOUT=true

NOTIFICATION_TYPE=redis

# Notification buffer size (for channel type)
NOTIFICATION_BUFFER_SIZE=1000

#################################
# cron scheduler timezone
#################################
# IANA timezone used to interpret cron expressions registered as CronScheduler.
# Falls back to TZ when unset, then UTC.
#CONDUCTOR_CRON_TIMEZONE=Asia/Tokyo
